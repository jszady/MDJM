# Resend — required for the contact form
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender shown in the "From" field — must be a Resend-verified domain/email
# Example: MJDM <info@mjdm.io>
RESEND_FROM_EMAIL=MJDM <info@mjdm.io>

# Inbox that receives contact submissions (defaults to siteConfig.email if omitted)
CONTACT_TO_EMAIL=info@mjdm.io
